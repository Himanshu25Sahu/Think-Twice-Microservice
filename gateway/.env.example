NODE_ENV=development
PORT=5000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
FRONTEND_URL=http://localhost:3000

# Redis (optional - falls back to in-memory rate limiting)
REDIS_URL=redis://localhost:6379

# Rate limiting (demo-friendly defaults)
# Set RATE_LIMIT_ENABLED=false to disable all gateway rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=1500
RATE_LIMIT_DEFAULT_MAX=10000

# Downstream service URLs (use service base origin only, no path suffix)
AUTH_SERVICE_URL=http://localhost:5001
ORG_SERVICE_URL=http://localhost:5003
ENTRY_SERVICE_URL=http://localhost:5002
ANALYTICS_SERVICE_URL=http://localhost:5004

# Keepalive
# ENABLE_INTERNAL_KEEPALIVE - set to 'true' for the gateway to self-ping on an interval
# KEEPALIVE_INTERVAL_MS     - how often the internal scheduler fires (default: 4 min)
# KEEPALIVE_TIMEOUT_MS      - per-request HTTP timeout (default: 8s)
# KEEPALIVE_WAKE_RETRIES    - retries for 502/503 cold-start responses (default: 1)
# KEEPALIVE_RETRY_DELAY_MS  - wait before retry, Render cold starts take ~30s (default: 20s)
# KEEPALIVE_TOLERATE_WARNING_STATUS_CODES - warnings that still count as healthy for cron status
ENABLE_INTERNAL_KEEPALIVE=false
KEEPALIVE_INTERVAL_MS=240000
KEEPALIVE_TIMEOUT_MS=8000
KEEPALIVE_WAKE_RETRIES=1
KEEPALIVE_RETRY_DELAY_MS=20000
KEEPALIVE_TOLERATE_WARNING_STATUS_CODES=429,502,503
